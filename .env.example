# ═══════════════════════════════════════════
# Cinder API Connection
# ═══════════════════════════════════════════
CINDER_API_URL=                                     # REQUIRED — URL of your own Cinder instance
CINDER_API_KEY=                               # Optional: if Cinder has API key auth

# ═══════════════════════════════════════════
# MCP Server Identity
# ═══════════════════════════════════════════
MCP_SERVER_NAME=cinder-mcp
MCP_SERVER_VERSION=1.0.0
PORT=3000                                      # MCP server HTTP port

# ═══════════════════════════════════════════
# OAuth 2.1 (REQUIRED for production HTTP)
# ═══════════════════════════════════════════
OAUTH_ENABLED=false
OAUTH_ISSUER=
OAUTH_AUDIENCE=
OAUTH_SCOPES=scrape,crawl,search

# ═══════════════════════════════════════════
# Redis (Session Management — required for multi-instance / production)
# ═══════════════════════════════════════════
REDIS_URL=
MCP_SESSION_MANAGER=memory                        # Options: memory, redis

# ═══════════════════════════════════════════
# Rate Limiting
# ═══════════════════════════════════════════
RATE_LIMIT_WINDOW_MS=60000                      # 1 minute
RATE_LIMIT_MAX=60                               # 60 requests per window

# ═══════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════
LOG_LEVEL=info                                  # Options: debug, info, warn, error
